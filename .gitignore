# 依存関係・ビルド成果物
node_modules/
dist/
.DS_Store

# 環境変数（シークレットを含む可能性があるため必ず除外）
.env
.env.*
!.env.example

# Rust ビルド成果物
src-tauri/target/

# ── Android ──────────────────────────────────────────
# ビルド成果物
src-tauri/gen/android/app/build/
src-tauri/gen/android/build/
src-tauri/gen/android/.gradle/
src-tauri/gen/android/buildSrc/.gradle/
src-tauri/gen/android/buildSrc/build/

# IDE 設定（自動生成）
src-tauri/gen/android/.idea/

# ローカル環境依存（SDK パスなど）
src-tauri/gen/android/local.properties

# 署名キー（絶対にコミットしない）
*.keystore
*.jks

# ── iOS ──────────────────────────────────────────────
# ビルド成果物
src-tauri/gen/apple/build/

# CocoaPods
src-tauri/gen/apple/Pods/

# Xcode ユーザー固有データ
src-tauri/gen/apple/**/*.xcuserstate
src-tauri/gen/apple/**/xcuserdata/

# ログ
*.log
npm-debug.log*

# Claude Code
.claude/worktrees/
