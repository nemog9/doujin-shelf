{
  "identifier": "default",
  "description": "Default capabilities for voice-csv-viewer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",
    "dialog:allow-open",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    }
  ]
}
